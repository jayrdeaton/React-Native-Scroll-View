{
  "name": "@rific/scroll-view",
  "version": "0.3.0",
  "description": "Blur styled scroll system for React Native. Floating headers/footers, keyboard awareness, and scroll-away chrome",
  "keywords": [
    "react-native",
    "expo",
    "scroll-view",
    "blur",
    "header",
    "footer",
    "keyboard-aware",
    "reanimated",
    "gesture-handler"
  ],
  "homepage": "https://github.com/jayrdeaton/react-native-scroll-view#readme",
  "bugs": {
    "url": "https://github.com/jayrdeaton/react-native-scroll-view/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jayrdeaton/react-native-scroll-view.git"
  },
  "license": "MIT",
  "author": "Jay Deaton",
  "sideEffects": false,
  "type": "commonjs",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "react-native": "src/index.ts",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "!src/__tests__",
    "!src/__mocks__"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "fix": "eslint --fix",
    "lint": "eslint",
    "prepublishOnly": "npm run build",
    "release": "git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:patch": "npm version patch && git push --follow-tags",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "typecheck": "tsc --noEmit",
    "preversion": "npm run lint && npm test && npm run build"
  },
  "devDependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "@rific/auto-paper": "^0.6.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.0.0",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-package-json": "^1.0.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-native": "^0.76.0",
    "react-native-gesture-handler": "*",
    "react-native-keyboard-controller": "*",
    "react-native-paper": "^5.12.0",
    "react-native-reanimated": "*",
    "react-native-safe-area-context": "*",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.59.3"
  },
  "peerDependencies": {
    "@rific/auto-paper": "^0.6.0",
    "react": ">=18.0.0",
    "react-native": ">=0.76.0",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-keyboard-controller": ">=1.0.0",
    "react-native-paper": ">=5.0.0",
    "react-native-reanimated": ">=3.0.0",
    "react-native-safe-area-context": ">=5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
